            </div>
          </div>
          <p class="mt-[24px] text-ink-faint text-[15px] leading-[1.7]">解牌的意义从来不只是答案:一是拓展信息,二是锻炼意识,三是给自己一件趁手的工具。800 场域过于耗神,日常未必深解——知道有这一层,便够了。</p>
        </div>
      </section>
    </div>
  </div>
</BaseLayout>

<script>
  // ClientRouter 下:进入占卜守则页初始化,离开前清理监听,避免泄漏到其它页。
  // 用独立 id(dvprogress / d1..d6 / data-d)与教程页区隔,互不串扰。
  let teardown: (() => void) | null = null;
  function initDivination() {
    const prog = document.getElementById('dvprogress');
    if (!prog) return; // 不在占卜守则页
    function onScroll() {
      const h = document.documentElement;
      const max = h.scrollHeight - h.clientHeight;
      if (prog) prog.style.width = (max > 0 ? (h.scrollTop / max * 100) : 0) + '%';
    }
    document.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
    const links = document.querySelectorAll('[data-d]');
    const secs = ['d1','d2','d3','d4','d5','d6','d7'].map(id => document.getElementById(id));
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          links.forEach(a => a.classList.toggle('on', a.getAttribute('data-d') === e.target.id));
        }
      });
    }, { rootMargin: '-30% 0px -60% 0px', threshold: 0 });
    secs.forEach(s => { if (s) io.observe(s); });
    teardown = () => { document.removeEventListener('scroll', onScroll); io.disconnect(); };
  }
  document.addEventListener('astro:page-load', initDivination);
  document.addEventListener('astro:before-swap', () => { if (teardown) { teardown(); teardown = null; } });
</script>

