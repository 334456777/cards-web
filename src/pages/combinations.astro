---
import BaseLayout from "../layouts/BaseLayout.astro";
import Divider from "../components/Divider.astro";
import { getCollection } from "astro:content";
import type { ComboData } from "../lib/cards";

const comboEntries = await getCollection("combinations");
const combos = comboEntries.map(e => ({ key: e.id, ...e.data })) as ({ key: string } & ComboData)[];

const SUITS = ["hearts", "spades", "diamonds", "clubs"];
const SYM: Record<string, string> = { hearts: "♥", spades: "♠", diamonds: "♦", clubs: "♣" };
const CLS: Record<string, string> = { hearts: "r", spades: "k", diamonds: "r", clubs: "k" };
const CN: Record<string, string> = { hearts: "红桃", spades: "黑桃", diamonds: "方块", clubs: "梅花" };

function pairKey(a: string, b: string) { return [a, b].sort().join("|"); }

// 构建配对查找表（二花色组合）
const pairMap = new Map<string, { key: string } & ComboData>();
for (const c of combos) {
  if (c.suits.length === 2) {
    const k = pairKey(c.suits[0], c.suits[1]);
    pairMap.set(k, c);
  }
}

// 组合数据通过 define:vars 传给客户端 JS（Astro 自动序列化）
---

<BaseLayout title="组合浏览器" activeNav="组合浏览器">
  <nav class="max-w-[1200px] mx-auto px-7 pt-5 font-sans text-[13.5px] text-ink-faint flex gap-[9px] items-center">
    <a href="/" class="text-ink-faint hover:text-coral">首页</a>
    <span class="text-line">›</span>
    <span class="text-suit-red font-medium">组合浏览器</span>
  </nav>

  <div class="max-w-[1200px] mx-auto px-7 pt-[18px] pb-[6px]">
    <div class="font-sans text-[13px] tracking-[0.22em] uppercase text-gold font-bold mb-3">花色相遇 · 嵌套 / 依存 / 转化</div>
    <h1 class="font-serif font-black text-[56px] leading-[1.04] mb-3 flex items-baseline gap-4 flex-wrap">
      组合浏览器
      <span class="text-[34px] tracking-[2px]"><span class="text-suit-red">♥</span><span class="text-ink">♠</span><span class="text-suit-red">♦</span><span class="text-ink">♣</span></span>
    </h1>
    <p class="text-[19px] text-ink-soft max-w-[32em] leading-[1.7]">花色从不孤立。两色、三色同现,会嵌套、依存、转化出新的状态。体系里组合无穷,这里只收精选——点开配对矩阵任意一格,或在下方画廊里翻阅。</p>
  </div>

  <Divider />

  <main class="max-w-[1200px] mx-auto px-7 pb-[100px]">
    <h2 class="font-sans text-[13px] font-bold tracking-[0.18em] uppercase text-gold mt-[42px] mb-2 flex items-center gap-[11px]">
      花色配对矩阵
      <span class="flex-1 h-px bg-line" />
    </h2>
    <p class="font-sans text-sm text-ink-faint mb-[22px] max-w-[44em]">行 × 列 = 两种花色相遇。点亮珊瑚点的格子已收录精选释义;斜线格是同色相叠(见四花色页);其余配对体系中存在,但本站尚未收录。</p>

    <div class="matrixwrap">
      <div class="font-sans">
        <div class="mgrid">
          <!-- 角 -->
          <div class="mcorner">行+列</div>
          <!-- 列头 -->
          {SUITS.map(c => <div class:list={["mhead", CLS[c] === "r" ? "r" : "k"]}>{SYM[c]}</div>)}
          <!-- 行 -->
          {SUITS.map(r => (
            <>
              <div class:list={["mhead", CLS[r] === "r" ? "r" : "k"]}>{SYM[r]}</div>
              {SUITS.map(c => {
                if (r === c) {
                  return <a href="/suits" class="mcell diag" title={CN[r] + " · 同色相叠"}>
                    <span class:list={["ps", CLS[r]]}>{SYM[r]}</span>
                  </a>;
                }
                const k = pairKey(r, c);
                const curated = pairMap.has(k);
                return <div
                  class:list={["mcell", curated && "curated"]}
                  data-pair={k}
                  data-a={r}
                  data-b={c}
                  title={CN[r] + " + " + CN[c]}
                >
                  <span class:list={["ps", CLS[r]]}>{SYM[r]}</span>
                  <span class:list={["ps", CLS[c]]}>{SYM[c]}</span>
                  {curated && <span class="dot-coral"></span>}
                </div>;
              })}
            </>
          ))}
        </div>
        <div class="mlegend">
          <span><span class="dot-coral inline"></span>已收录精选</span>
          <span><span class="sw"></span>可点击</span>
          <span><span class="sw diag-sw"></span>同色相叠</span>
        </div>
      </div>

      <!-- 详情面板 -->
      <div class="detail" id="detail">
        <div class="empty-state">
          <div class="empty-keys"><span class="s r">♥</span><span class="plus">+</span><span class="s k">♣</span></div>
          <div class="eg">❦</div>
          <div class="et">点开矩阵任意一格</div>
          <div class="ed">选择一种花色配对,查看它在落差体系中的含义。</div>
        </div>
      </div>
    </div>

    <h2 class="font-sans text-[13px] font-bold tracking-[0.18em] uppercase text-gold mt-[42px] mb-2 flex items-center gap-[11px]">
      精选组合 · 画廊
      <span class="flex-1 h-px bg-line" />
    </h2>
    <p class="font-sans text-sm text-ink-faint mb-[22px] max-w-[44em]">收录的组合一览。用花色筛选,只看包含某一花色的组合。</p>

    <!-- 画廊花色筛选器 -->
    <div class="filters" id="filters">
      <span class="flabel">含花色</span>
      <button class="chip on" data-f="all">全部</button>
      <button class="chip" data-f="hearts"><span class="s r">♥</span>红桃</button>
      <button class="chip" data-f="spades"><span class="s k">♠</span>黑桃</button>
      <button class="chip" data-f="diamonds"><span class="s r">♦</span>方块</button>
      <button class="chip" data-f="clubs"><span class="s k">♣</span>梅花</button>
    </div>

    <div class="gallery" id="gallery">
      {combos.map((c) => (
        <div
          class:list={["gcard", c.warn && "warn"]}
          data-suits={c.suits.join(" ")}
        >
          <span class:list={["gtag", c.warn && "warn-tag"]}>
            {c.warn ? "特例" : "精选"}
          </span>
          <div class="gkeys">
            {c.suits.map((s, i) => (
              <>
                {i > 0 && <span class="plus">+</span>}
                <span class:list={["s", CLS[s]]}>{SYM[s]}</span>
              </>
            ))}
            <span class:list={["name", c.warn && "warn-name"]}>{c.name}</span>
          </div>
          <div class="gyy">{c.yy}</div>
          <div class="grow pos">
            <span class="grl">显义 · 一面</span>
            <p>{c.pos}</p>
          </div>
          <div class="grow neg">
            <span class="grl">隐义 · 反面</span>
            <p>{c.neg}</p>
          </div>
        </div>
      ))}
    </div>
  </main>
</BaseLayout>

<script define:vars={{ SUITS, SYM, CLS, CN, combos }}>
  // pairKey 辅助函数（函数无法通过 define:vars 序列化，在此直接定义）
  function pairKey(a, b) { return [a, b].sort().join("|"); }

  // ClientRouter 下:每次进入组合页重新初始化(define:vars 只能写纯 JS)
  function initCombos() {
  const detail = document.getElementById('detail');
  if (!detail) return; // 不在组合页
  // COMBO_DATA 由 Astro 直接序列化注入，无需 JSON.parse
  const COMBO_DATA = combos;

  // 按配对 key 索引（二花色组合）
  const comboByPair = new Map();
  // 按 suits 字符串索引（多花色组合）
  const comboBySuits = new Map();
  for (const c of COMBO_DATA) {
    if (c.suits.length === 2) {
      const pk = pairKey(c.suits[0], c.suits[1]);
      comboByPair.set(pk, c);
    }
    // 也存入 suits 排序后的 key（三花色等）
    comboBySuits.set([...c.suits].sort().join("|"), c);
  }

  function renderDetail(data, a, b) {
    detail.className = 'detail';
    detail.innerHTML = `
      <div class="dkeys">
        ${data.suits.map(s => `<span class="s ${CLS[s]}">${SYM[s]}</span>`).join('<span class="plus">+</span>')}
      </div>
      <h3>${data.name}</h3>
      <div class="dyy">${data.yy}</div>
      <div class="drow pos"><span class="drl">显义 · 一面</span><p>${data.pos}</p></div>
      <div class="drow neg"><span class="drl">隐义 · 反面</span><p>${data.neg}</p></div>
    `;
  }

  function renderEmpty(a, b) {
    detail.className = 'detail';
    detail.innerHTML = `
      <div class="empty-state">
        <div class="empty-keys">
          <span class="s ${CLS[a]}">${SYM[a]}</span>
          <span class="plus">+</span>
          <span class="s ${CLS[b]}">${SYM[b]}</span>
        </div>
        <div class="eg">❦</div>
        <div class="et">${CN[a]} + ${CN[b]} · 尚未收录</div>
        <div class="ed">这一配对在体系中确实存在,但本站只收精选。可先分别读两种花色的性格,按语境自行叠合。</div>
      </div>
    `;
  }

  function selectPair(k, a, b) {
    // 更新矩阵选中态
    document.querySelectorAll('.mcell').forEach(cell => {
      const isMatch = cell.getAttribute('data-pair') === k;
      cell.style.boxShadow = isMatch ? 'inset 0 0 0 2px #D97757' : '';
      cell.style.borderColor = isMatch ? '#D97757' : '';
    });

    const data = comboByPair.get(k);
    if (data) {
      renderDetail(data, a, b);
    } else {
      renderEmpty(a, b);
    }
  }

  // 绑定矩阵格子点击
  document.querySelectorAll('.mcell:not(.diag)').forEach(cell => {
    cell.addEventListener('click', () => {
      const k = cell.getAttribute('data-pair');
      const a = cell.getAttribute('data-a');
      const b = cell.getAttribute('data-b');
      if (k && a && b) selectPair(k, a, b);
    });
  });

  // 默认选中红桃+梅花
  const defaultPair = pairKey('hearts', 'clubs');
  selectPair(defaultPair, 'hearts', 'clubs');

  // 画廊花色筛选
  let fstate = 'all';
  document.getElementById('filters')?.addEventListener('click', function(e) {
    const b = e.target.closest('.chip');
    if (!b) return;
    const parent = b.parentElement;
    parent.querySelectorAll('.chip').forEach(c => c.classList.remove('on'));
    b.classList.add('on');
    fstate = b.getAttribute('data-f') || 'all';
    document.querySelectorAll('.gcard').forEach(c => {
      const suits = c.getAttribute('data-suits') || '';
      const has = fstate === 'all' || suits.indexOf(fstate) > -1;
      c.classList.toggle('hide', !has);
    });
  });
  }
  if (!window.__combosBound) {
    window.__combosBound = true;
    document.addEventListener('astro:page-load', initCombos);
  }
</script>

<style>
  /* ===== 配对矩阵 ===== */
  .matrixwrap {
    display: grid;
    grid-template-columns: minmax(0, 420px) 1fr;
    gap: 38px;
    align-items: start;
  }
  .mgrid {
    display: grid;
    grid-template-columns: 46px repeat(4, 1fr);
    grid-template-rows: 46px repeat(4, 1fr);
    gap: 6px;
  }
  .mhead {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    line-height: 1;
  }
  .mhead.r { color: #A3372B; }
  .mhead.k { color: #2B2722; }
  .mcorner {
    display: flex;
    align-items: center;
    justify-content: center;
    color: #8b8173;
    font-size: 11px;
    letter-spacing: 0.06em;
    text-align: center;
    font-weight: 700;
    font-family: "Noto Sans SC", sans-serif;
  }
  .mcell {
    aspect-ratio: 1;
    border: 1px solid #d8ccb6;
    border-radius: 9px;
    background: #F4EDE0;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    position: relative;
    transition: all 0.2s;
    gap: 2px;
    text-decoration: none;
    color: inherit;
  }
  .mcell .ps {
    font-size: 17px;
    line-height: 1;
  }
  .mcell .ps.r { color: #A3372B; }
  .mcell .ps.k { color: #2B2722; }
  .mcell.diag {
    background: repeating-linear-gradient(45deg, #EFE6D6, #EFE6D6 5px, #F4EDE0 5px, #F4EDE0 10px);
    cursor: pointer;
    text-decoration: none;
  }
  .mcell.diag .ps { opacity: 0.4; }
  .mcell.curated {
    background: #fff;
    border-color: #B8893A;
  }
  .mcell.curated::after {
    content: "";
    position: absolute;
    top: 5px;
    right: 5px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #D97757;
  }
  .mcell:not(.diag):hover {
    border-color: #D97757;
    transform: translateY(-2px);
  }
  .mcell.diag:hover {
    border-color: #D97757;
    transform: translateY(-2px);
  }

  /* 图例 */
  .mlegend {
    display: flex;
    gap: 18px;
    margin-top: 16px;
    font-size: 12.5px;
    color: #8b8173;
    flex-wrap: wrap;
    font-family: "Noto Sans SC", sans-serif;
  }
  .mlegend span {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .dot-coral {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #D97757;
    display: block;
    flex-shrink: 0;
  }
  .dot-coral.inline {
    display: inline-block;
  }
  .sw {
    width: 14px;
    height: 14px;
    border-radius: 4px;
    border: 1px solid #B8893A;
    background: #fff;
    display: block;
    flex-shrink: 0;
  }
  .sw.diag-sw {
    background: repeating-linear-gradient(45deg, #EFE6D6, #EFE6D6 3px, #F4EDE0 3px, #F4EDE0 6px);
    border-color: #d8ccb6;
  }

  /* ===== 详情面板 ===== */
  .detail {
    background: #F4EDE0;
    border: 1px solid #d8ccb6;
    border-radius: 16px;
    padding: 30px 32px;
    position: relative;
    min-height: 300px;
  }
  .detail::after {
    content: "";
    position: absolute;
    inset: 8px;
    border-radius: 11px;
    pointer-events: none;
    border: 1.5px solid #B8893A;
    opacity: 0.16;
    filter: url(#rough);
  }
  .detail .dkeys {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 6px;
  }
  .detail .dkeys .s {
    font-size: 38px;
    line-height: 1;
  }
  .detail .dkeys .s.r { color: #A3372B; }
  .detail .dkeys .s.k { color: #2B2722; }
  .detail .dkeys .plus { color: #B8893A; font-size: 22px; }
  .detail h3 {
    font-family: "Noto Serif SC", serif;
    font-weight: 900;
    font-size: 30px;
    margin: 6px 0 2px;
  }
  .detail .dyy {
    font-family: "Noto Sans SC", sans-serif;
    font-size: 13px;
    color: #8b8173;
    letter-spacing: 0.05em;
    margin-bottom: 18px;
  }
  .detail .drow { margin-bottom: 15px; }
  .detail .drl {
    font-family: "Noto Sans SC", sans-serif;
    font-size: 11.5px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 5px;
    display: inline-block;
  }
  .detail .drow.pos .drl { color: #D97757; }
  .detail .drow.neg .drl { color: #8b8173; }
  .detail .drow p { margin: 0; font-size: 16.5px; line-height: 1.7; color: #5b5246; }
  .detail .drow.pos p { color: #2B2722; }

  /* 空状态 */
  .detail .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: #8b8173;
    height: 100%;
    min-height: 280px;
  }
  .detail .empty-keys {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
  }
  .detail .empty-keys .s {
    font-size: 38px;
    line-height: 1;
  }
  .detail .empty-keys .s.r { color: #A3372B; }
  .detail .empty-keys .s.k { color: #2B2722; }
  .detail .empty-keys .plus { color: #B8893A; font-size: 22px; }
  .detail .eg { font-size: 40px; color: #d8ccb6; margin-bottom: 12px; }
  .detail .et {
    font-family: "Noto Serif SC", serif;
    font-size: 21px;
    color: #5b5246;
    margin-bottom: 8px;
  }
  .detail .ed {
    font-family: "Noto Sans SC", sans-serif;
    font-size: 14px;
    max-width: 24em;
    line-height: 1.6;
  }

  /* ===== 筛选器 ===== */
  .filters {
    display: flex;
    align-items: center;
    gap: 9px;
    flex-wrap: wrap;
    font-family: "Noto Sans SC", sans-serif;
    margin-bottom: 22px;
  }
  .flabel {
    font-size: 12px;
    color: #8b8173;
    letter-spacing: 0.1em;
    font-weight: 700;
    text-transform: uppercase;
    margin-right: 4px;
  }
  .filters .chip {
    font-size: 14px;
    font-weight: 500;
    color: #5b5246;
    border: 1px solid #d8ccb6;
    background: #F4EDE0;
    border-radius: 30px;
    padding: 6px 15px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 6px;
    transition: all 0.2s;
    white-space: nowrap;
    line-height: 1.2;
  }
  .filters .chip:hover { border-color: #D97757; color: #2B2722; }
  .filters .chip.on { background: #D97757; border-color: #D97757; color: #fff; }
  .filters .chip.on .s.r,
  .filters .chip.on .s.k { color: #fff; }
  .filters .chip .s.r { color: #A3372B; }
  .filters .chip .s.k { color: #2B2722; }

  /* ===== 画廊 ===== */
  .gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(330px, 1fr));
    gap: 20px;
  }
  .gcard {
    border: 1px solid #d8ccb6;
    border-radius: 14px;
    background: #F4EDE0;
    padding: 24px 26px;
    position: relative;
    transition: border-color 0.22s, transform 0.22s, box-shadow 0.22s;
  }
  .gcard:hover {
    border-color: #D97757;
    transform: translateY(-3px);
    box-shadow: 0 16px 30px -18px rgba(43, 39, 34, 0.45);
  }
  .gcard.hide { display: none; }
  .gcard .gkeys {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
  }
  .gcard .gkeys .s {
    font-size: 27px;
    line-height: 1;
  }
  .gcard .gkeys .s.r { color: #A3372B; }
  .gcard .gkeys .s.k { color: #2B2722; }
  .gcard .gkeys .plus { color: #B8893A; font-size: 16px; }
  .gcard .gkeys .name {
    font-family: "Noto Serif SC", serif;
    font-weight: 700;
    font-size: 19px;
    margin-left: 7px;
    color: #2B2722;
  }
  .gcard .gkeys .name.warn-name { color: #A3372B; }
  .gcard .gyy {
    font-family: "Noto Sans SC", sans-serif;
    font-size: 13px;
    color: #8b8173;
    letter-spacing: 0.05em;
    margin-bottom: 13px;
  }
  .gcard .grow { margin-bottom: 11px; }
  .gcard .grl {
    font-family: "Noto Sans SC", sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 4px;
    display: inline-block;
  }
  .gcard .grow.pos .grl { color: #D97757; }
  .gcard .grow.neg .grl { color: #8b8173; }
  .gcard .grow p {
    margin: 0;
    font-size: 15.5px;
    line-height: 1.64;
    color: #5b5246;
  }
  .gcard .grow.pos p { color: #2B2722; }
  .gcard.warn { background: #f8ece9; border-color: #d9a59c; }
  .gcard .gtag {
    position: absolute;
    top: 18px;
    right: 20px;
    font-family: "Noto Sans SC", sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #B8893A;
    border: 1px solid #B8893A;
    border-radius: 20px;
    padding: 2px 10px;
    opacity: 0.7;
  }
  .gcard .gtag.warn-tag {
    color: #A3372B;
    border-color: #d9a59c;
  }

  /* 响应式 */
  @media (max-width: 900px) {
    .matrixwrap {
      grid-template-columns: 1fr;
      gap: 26px;
    }
    .mgrid {
      max-width: 420px;
      margin: 0 auto;
      width: 100%;
    }
    .gallery {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 760px) {
    main { padding: 0 18px 70px; }
  }
</style>
