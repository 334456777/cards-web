---
import BaseLayout from "../layouts/BaseLayout.astro";
import Divider from "../components/Divider.astro";

const links = [
  { href: "/", label: "回首页" },
  { href: "/tutorial", label: "教程" },
  { href: "/library", label: "牌库" },
  { href: "/suits", label: "四花色" },
  { href: "/combinations", label: "组合浏览器" },
];
---

<BaseLayout title="页面走丢了 · 404">
  <main class="max-w-[760px] mx-auto px-7 pt-[88px] pb-[120px] text-center">
    <div class="font-sans text-[13px] tracking-[0.24em] uppercase text-gold font-bold mb-6">
      404 · 此牌不在牌库
    </div>

    <div class="flex items-center justify-center gap-[14px] text-[58px] leading-none mb-7 [filter:url(#rough)]">
      <span class="text-suit-red">♥</span>
      <span class="text-ink">♠</span>
      <span class="text-gold text-[44px]">❦</span>
      <span class="text-suit-red">♦</span>
      <span class="text-ink">♣</span>
    </div>

    <h1 class="font-serif font-black text-[56px] leading-[1.08] mb-[18px] tracking-[0.01em]">
      这一页,翻空了
    </h1>
    <p class="text-[19px] text-ink-soft max-w-[28em] mx-auto leading-[1.74] mb-1">
      你要找的牌不在这副牌里——也许链接抄错了一个字,也许它本就还在叠加态中,<span class="text-suit-red font-bold">尚未坍缩</span>成一张确定的页面。
    </p>
    <p class="text-[16px] text-ink-faint max-w-[26em] mx-auto leading-[1.7]">
      从下面任意一个入口,重新翻起。
    </p>

    <Divider />

    <div class="flex flex-wrap justify-center gap-3 font-sans text-[14.5px] font-semibold mt-[40px]">
      {links.map((l) => (
        <a
          href={l.href}
          class="inline-flex items-center gap-2 rounded-[30px] px-[22px] py-[10px] border transition-all no-underline bg-paper-deep border-line text-ink-soft hover:border-coral hover:text-ink hover:-translate-y-[2px]"
        >
          {l.label}
          <span class="text-gold">→</span>
        </a>
      ))}
    </div>
  </main>
</BaseLayout>
