---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";

interface Props {
  title: string;
  activeNav?: "教程" | "占卜守则" | "牌库" | "四花色" | "组合浏览器";
}

const { title, activeNav } = Astro.props;
---
<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} · 落差扑克牌占卜</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <!-- 客户端路由:换页不刷新,卡片转场在其生命周期里完成 -->
  <ClientRouter />
</head>
<body>
  <!-- SVG 纹理滤镜（全局共用） -->
  <svg class="rough-filter" aria-hidden="true">
    <defs>
      <filter id="rough">
        <feTurbulence type="fractalNoise" baseFrequency="0.018" numOctaves="3" seed="7" result="n" />
        <feDisplacementMap in="SourceGraphic" in2="n" scale="3.2" xChannelSelector="R" yChannelSelector="G" />
      </filter>
    </defs>
  </svg>

  <div class="page-wrap">
    <!-- 导航栏 -->
    <header class="sticky top-0 z-40 border-b border-line bg-[rgba(250,246,239,0.88)] backdrop-blur-[8px] font-sans">
      <div class="max-w-[1200px] mx-auto px-7 py-[14px] flex items-center gap-[22px]">
        <a href="/" class="flex items-center gap-[11px] font-bold tracking-[0.02em] text-ink text-base no-underline">
          <span class="font-serif text-[21px] text-suit-red leading-none tracking-[-2px]">
            <span>♥</span><span class="text-ink">♠</span>
          </span>
          <span>落差扑克牌占卜</span>
        </a>
        <nav class="ml-auto hidden sm:flex gap-[26px] text-[14.5px] font-medium">
          <a href="/tutorial" class:list={["text-ink-soft hover:text-coral py-1.5", activeNav === "教程" && "text-suit-red"]}>教程</a>
          <a href="/divination" class:list={["text-ink-soft hover:text-coral py-1.5", activeNav === "占卜守则" && "text-suit-red"]}>占卜守则</a>
          <a href="/library" class:list={["text-ink-soft hover:text-coral py-1.5", activeNav === "牌库" && "text-suit-red"]}>牌库</a>
          <a href="/suits" class:list={["text-ink-soft hover:text-coral py-1.5", activeNav === "四花色" && "text-suit-red"]}>四花色</a>
          <a href="/combinations" class:list={["text-ink-soft hover:text-coral py-1.5", activeNav === "组合浏览器" && "text-suit-red"]}>组合浏览器</a>
        </nav>
        <!-- 移动端汉堡按钮 -->
        <button
          id="navToggle"
          type="button"
          aria-label="打开导航菜单"
          aria-expanded="false"
          aria-controls="mobileNav"
          class="nav-toggle ml-auto sm:hidden inline-flex flex-col justify-center items-center gap-[5px] w-10 h-10 -mr-2 rounded-lg cursor-pointer"
        >
          <span class="bar block w-[22px] h-[2px] bg-ink rounded-full"></span>
          <span class="bar block w-[22px] h-[2px] bg-ink rounded-full"></span>
          <span class="bar block w-[22px] h-[2px] bg-ink rounded-full"></span>
        </button>
      </div>
      <!-- 移动端下拉菜单 -->
      <nav id="mobileNav" class="mobile-nav sm:hidden hidden absolute top-full inset-x-0 z-50 border-t border-line bg-paper font-medium text-[15.5px] shadow-[0_16px_30px_-12px_rgba(43,39,34,0.45)]">
        <a href="/tutorial" class:list={["block px-7 py-[13px] border-b border-line text-ink-soft hover:text-coral hover:bg-paper-deep", activeNav === "教程" && "text-suit-red"]}>教程</a>
        <a href="/divination" class:list={["block px-7 py-[13px] border-b border-line text-ink-soft hover:text-coral hover:bg-paper-deep", activeNav === "占卜守则" && "text-suit-red"]}>占卜守则</a>
        <a href="/library" class:list={["block px-7 py-[13px] border-b border-line text-ink-soft hover:text-coral hover:bg-paper-deep", activeNav === "牌库" && "text-suit-red"]}>牌库</a>
        <a href="/suits" class:list={["block px-7 py-[13px] border-b border-line text-ink-soft hover:text-coral hover:bg-paper-deep", activeNav === "四花色" && "text-suit-red"]}>四花色</a>
        <a href="/combinations" class:list={["block px-7 py-[13px] text-ink-soft hover:text-coral hover:bg-paper-deep", activeNav === "组合浏览器" && "text-suit-red"]}>组合浏览器</a>
      </nav>
    </header>

    <!-- 飞行浮层:跨换页持久,克隆牌在此飞行,被导航栏 / 筛选栏遮挡(见 global.css #cf-portal) -->
    <div id="cf-portal" transition:persist="cardflip" aria-hidden="true"></div>

    <!-- 内容层:换页时的退场 / 入场动画作用于此,导航栏在其外故不参与 -->
    <div class="cf-content">
      <slot />

      <!-- 页脚 -->
      <footer class="border-t border-line mt-[70px] font-sans text-[13px] text-ink-faint">
        <div class="max-w-[1200px] mx-auto px-7 py-[30px] flex justify-between gap-5 flex-wrap">
          <span>落差扑克牌占卜 · 一套非线性、叠加态的解牌体系</span>
          <span class="flex flex-wrap gap-x-1 gap-y-1 items-center">
            <a href="/tutorial" class="inline-block py-1">教程</a> ·
            <a href="/divination" class="inline-block py-1">占卜守则</a> ·
            <a href="/library" class="inline-block py-1">牌库索引</a> ·
            <a href="/suits" class="inline-block py-1">四花色</a> ·
            <a href="/combinations" class="inline-block py-1">组合浏览器</a>
          </span>
        </div>
      </footer>
    </div>
  </div>

  <script>
    import { navigate } from "astro:transitions/client";

    // ── 移动端导航(每次换页都重新绑定,因 header 会被换掉) ──
    function initNav() {
      const navToggle = document.getElementById("navToggle");
      const mobileNav = document.getElementById("mobileNav");
      if (!navToggle || !mobileNav) return;
      const setOpen = (open: boolean) => {
        mobileNav.classList.toggle("hidden", !open);
        navToggle.setAttribute("aria-expanded", open ? "true" : "false");
        navToggle.classList.toggle("is-open", open);
      };
      navToggle.addEventListener("click", () => setOpen(mobileNav.classList.contains("hidden")));
      mobileNav.querySelectorAll("a").forEach((a) => a.addEventListener("click", () => setOpen(false)));
    }
    document.addEventListener("astro:page-load", initNav);
    // 关闭叠层菜单的公共逻辑(顶层绑定一次,避免 SPA 换页时监听泄漏)
    const closeMobileNav = () => {
      const mn = document.getElementById("mobileNav"), nt = document.getElementById("navToggle");
      if (mn && nt) { mn.classList.add("hidden"); nt.setAttribute("aria-expanded", "false"); nt.classList.remove("is-open"); }
    };
    document.addEventListener("keydown", (e) => { if (e.key === "Escape") closeMobileNav(); });
    // 点击菜单与汉堡按钮以外的区域 → 收起叠层菜单
    document.addEventListener("click", (e) => {
      const mn = document.getElementById("mobileNav"), nt = document.getElementById("navToggle");
      if (!mn || !nt || mn.classList.contains("hidden")) return;
      const t = e.target as Node;
      if (mn.contains(t) || nt.contains(t)) return;
      closeMobileNav();
    });

    // ════════ 库 ↔ 单卡页转场:克隆牌全程压在两栏之下,背景两段式收 / 展 ════════
    // 点 /cards/ 链接 → 在持久浮层挂克隆牌,自原位起飞(被导航栏 / 筛选栏遮挡)。前半:牌库内容收缩渐隐 +
    // 筛选栏收起;到半程换页;后半:单卡页内容舒展渐显,克隆飞到真实 hero 落定 → 亮真卡。反向(返回牌库 /
    // 导航 / 后退)按生命周期跑入场:内容舒展渐显 + 有筛选栏则从收起态展开。reduced-motion / 刷新 / 直接进入静态。
    const HALF = 440;                                // 退场 / 入场各半;克隆飞行两段各 HALF(总 ~880ms)
    const EASE_IN = "cubic-bezier(0.4, 0, 1, 1)";    // A 段:加速离位,末端峰速
    const EASE_OUT = "cubic-bezier(0, 0, 0.2, 1)";   // B 段:从 A 的峰速减速落定,衔接无跳变
    const CARD_RATIO = 332.59947 / 238.11099;        // 正面 svg 长宽比(无卡面的链接据此估起飞矩形)
    const reduceMQ = window.matchMedia("(prefers-reduced-motion: reduce)");

    type Rect = { x: number; y: number; w: number; h: number };
    type Flight = { stage: HTMLElement; o: Rect; transit: string };
    let flight: Flight | null = null;                // 前向飞牌中(非 null);也用作「本次为飞牌进入」的判据
    let busy = false;                                // 转场进行中,吞掉重复点击
    let spaNav = false;                              // 本次换页为 SPA 导航(驱动入场;首屏 / 刷新为 false → 静态)

    const heroCard = () => document.querySelector("main .card") as HTMLElement | null;
    const portal = () => document.getElementById("cf-portal");
    const cfContent = () => document.querySelector(".cf-content") as HTMLElement | null;
    const clearPortal = () => portal()?.replaceChildren();
    const cardKey = (href: string) => {
      try { return new URL(href, location.href).pathname.replace(/^\/cards\//, "").replace(/\/$/, ""); }
      catch { return ""; }
    };
    const identity = "translate(0px, 0px) scale(1) rotate(0deg)";

    // 起飞矩形:库卡优先取「带边框卡面」.lcard,退回 img,再退回链接本身按 svg 比例估出卡形矩形
    function readOrigin(a: HTMLAnchorElement): Rect {
      const cardBox = a.querySelector(".lcard") || a.querySelector("img");
      if (cardBox) {
        const r = cardBox.getBoundingClientRect();
        return { x: r.left, y: r.top, w: r.width, h: r.height };
      }
      const r = a.getBoundingClientRect();
      const w = Math.min(110, r.width || 110), h = w * CARD_RATIO;
      return { x: r.left + (r.width - w) / 2, y: r.top + (r.height - h) / 2, w, h };
    }

    // 在持久浮层挂一张克隆牌:stage 框 = 起飞矩形,恒等 transform = 停在原位
    function mountClone(key: string, o: Rect): HTMLElement {
      const stage = document.createElement("div");
      stage.id = "cardflip-stage";
      stage.style.left = o.x + "px";
      stage.style.top = o.y + "px";
      stage.style.width = o.w + "px";
      stage.style.height = o.h + "px";
      stage.style.transform = identity;
      const card = document.createElement("div");
      card.className = "cf-card cf-lift";
      const img = document.createElement("img");
      img.src = `/cards_svg/${key}.svg`;
      img.alt = "";
      const frame = document.createElement("div");
      frame.className = "cf-frame";
      card.append(img, frame);
      stage.append(card);
      portal()?.append(stage);
      return stage;
    }

    // 中转锚点(A 段终点):朝估算 hero 位插值约 55%,精确落点由 B 段按真实 hero 校正
    function transitTransform(o: Rect): string {
      const small = window.innerWidth <= 760;
      const estScale = (small ? 240 : 300) / o.w;
      const ocx = o.x + o.w / 2, ocy = o.y + o.h / 2;
      const ecx = window.innerWidth / 2, ecy = 67 + (small ? 150 : 180);
      const t = 0.55;
      return `translate(${(ecx - ocx) * t}px, ${(ecy - ocy) * t}px) scale(${1 + (estScale - 1) * t}) rotate(${-2 * t}deg)`;
    }

    // 落点 transform:让 stage(锚于原位)渲染框对齐真实 hero,落定回 -2°(与单卡页 .card 静止角一致)
    function heroTransform(o: Rect, hero: HTMLElement): string {
      const r = hero.getBoundingClientRect();
      const ocx = o.x + o.w / 2, ocy = o.y + o.h / 2;
      const hcx = r.left + r.width / 2, hcy = r.top + r.height / 2;
      return `translate(${hcx - ocx}px, ${hcy - ocy}px) scale(${r.width / o.w}) rotate(-2deg)`;
    }

    // 背景退场:.cf-content 收缩渐隐 +(有则)筛选栏收起
    function runExit() {
      cfContent()?.animate(
        [{ opacity: 1, transform: "scale(1)" }, { opacity: 0, transform: "scale(0.96)" }],
        { duration: HALF, easing: EASE_IN, fill: "forwards" }
      );
      document.querySelector(".cf-filterbar")?.animate(
        [{ opacity: 1, transform: "scaleY(1)" }, { opacity: 0, transform: "scaleY(0)" }],
        { duration: HALF, easing: EASE_IN, fill: "forwards" }
      );
    }

    // 背景入场:.cf-content 舒展渐显 +(有则)筛选栏从收起态展开;结束后清掉预隐藏的内联样式
    function runEnter() {
      const c = cfContent();
      if (c) {
        const a = c.animate(
          [{ opacity: 0, transform: "scale(0.97)" }, { opacity: 1, transform: "scale(1)" }],
          { duration: HALF, easing: EASE_OUT, fill: "both" }
        );
        a.addEventListener("finish", () => { c.style.opacity = ""; c.style.transform = ""; a.cancel(); }, { once: true });
      }
      document.querySelector(".cf-filterbar")?.animate(
        [{ opacity: 0, transform: "scaleY(0)" }, { opacity: 1, transform: "scaleY(1)" }],
        { duration: HALF, easing: EASE_OUT, fill: "both" }
      );
    }

    // 点击发起前向飞牌:挂克隆 → A 段(原位 → 中转)+ 牌库退场 → 半程后换页
    function startForward(href: string, o: Rect) {
      const stage = mountClone(cardKey(href), o);
      const transit = transitTransform(o);
      void stage.getBoundingClientRect();            // 提交初始 transform,A 段从同一起点接管,防首帧闪
      const a = stage.animate([{ transform: identity }, { transform: transit }], { duration: HALF, easing: EASE_IN, fill: "forwards" });
      flight = { stage, o, transit };
      (flight as any).a = a;
      runExit();
      window.setTimeout(() => navigate(href), HALF);
    }

    // 换页后落定:B 段(中转 → 真实 hero)+ 单卡页入场;落定卸浮起、亮真卡、清浮层
    function forwardLanding() {
      const f = flight; flight = null;
      const hero = heroCard();
      let done = false;
      const finish = () => { if (done) return; done = true; if (hero) hero.style.visibility = ""; clearPortal(); busy = false; };
      if (!f || !hero) { finish(); return; }
      (f as any).a?.cancel();
      const b = f.stage.animate([{ transform: f.transit }, { transform: heroTransform(f.o, hero) }], { duration: HALF, easing: EASE_OUT, fill: "forwards" });
      b.addEventListener("finish", () => {
        f.stage.querySelector(".cf-card")?.classList.remove("cf-lift");  // 投影经 0.5s 过渡收回 = 落下
        window.setTimeout(finish, 260);                                   // 投影收一截再亮真卡 / 清场
      }, { once: true });
      runEnter();
      window.setTimeout(finish, HALF + 900);                              // 看门狗:动画未触发也落定
    }

    // 捕获阶段(早于 ClientRouter):拦截 /cards/ 主键点击,改由本编排控制时序
    document.addEventListener("click", (e) => {
      const me = e as MouseEvent;
      if (me.button !== 0 || me.metaKey || me.ctrlKey || me.shiftKey || me.altKey) return;
      const a = (e.target as Element | null)?.closest?.('a[href^="/cards/"]') as HTMLAnchorElement | null;
      if (!a || a.target === "_blank" || reduceMQ.matches) return;
      let url: URL;
      try { url = new URL(a.href, location.href); } catch { return; }
      if (url.origin !== location.origin) return;
      e.preventDefault();
      if (busy) return;
      busy = true;
      startForward(a.href, readOrigin(a));
    }, true);

    // 离开页面前:清叠加态 body class;标记 SPA 导航;非前向才清浮层(前向克隆需跨换页存活)
    document.addEventListener("astro:before-swap", () => {
      document.body.classList.remove("reverse", "shadow");
      if (!reduceMQ.matches) spaNav = true;
      if (!flight) clearPortal();
    });

    // 换页瞬间:预隐藏内容避免入场前闪;前向再藏起目标 hero(由克隆代飞)
    document.addEventListener("astro:after-swap", () => {
      if (reduceMQ.matches) return;
      const c = cfContent();
      if (c) c.style.opacity = "0";
      if (flight) { const hero = heroCard(); if (hero) hero.style.visibility = "hidden"; }
    });

    // 换页完成:前向 → 落定;其余 SPA 进入 → 入场(返回牌库时筛选栏从收起态展开);直接进入 / 刷新静态
    document.addEventListener("astro:page-load", () => {
      if (flight) { forwardLanding(); spaNav = false; return; }
      if (spaNav && !reduceMQ.matches) runEnter();
      spaNav = false;
    });
  </script>

  <style>
    /* 汉堡按钮 → X 动画 */
    .nav-toggle .bar { transition: transform 0.25s ease, opacity 0.2s ease; }
    .nav-toggle.is-open .bar:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .nav-toggle.is-open .bar:nth-child(2) { opacity: 0; }
    .nav-toggle.is-open .bar:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

    /* 叠层菜单:出现时轻微下滑淡入(浮在内容之上,不挤压页面) */
    .mobile-nav:not(.hidden) { animation: navDrop 0.22s ease both; transform-origin: top; }
    @keyframes navDrop {
      from { opacity: 0; transform: translateY(-10px); }
      to   { opacity: 1; transform: translateY(0); }
    }
  </style>
</body>
</html>
