---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";

interface Props {
  title: string;
  activeNav?: "教程" | "牌库" | "四花色" | "组合浏览器";
}

const { title, activeNav } = Astro.props;
---
<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} · 落差扑克牌占卜</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <!-- 客户端路由:换页不刷新,卡片转场在其生命周期里完成 -->
  <ClientRouter />
</head>
<body>
  <!-- SVG 纹理滤镜（全局共用） -->
  <svg class="rough-filter" aria-hidden="true">
    <defs>
      <filter id="rough">
        <feTurbulence type="fractalNoise" baseFrequency="0.018" numOctaves="3" seed="7" result="n" />
        <feDisplacementMap in="SourceGraphic" in2="n" scale="3.2" xChannelSelector="R" yChannelSelector="G" />
      </filter>
    </defs>
  </svg>

  <div class="page-wrap">
    <!-- 导航栏 -->
    <header class="sticky top-0 z-40 border-b border-line bg-[rgba(250,246,239,0.88)] backdrop-blur-[8px] font-sans">
      <div class="max-w-[1200px] mx-auto px-7 py-[14px] flex items-center gap-[22px]">
        <a href="/" class="flex items-center gap-[11px] font-bold tracking-[0.02em] text-ink text-base no-underline">
          <span class="font-serif text-[21px] text-suit-red leading-none tracking-[-2px]">
            <span>♥</span><span class="text-ink">♠</span>
          </span>
          <span>落差扑克牌占卜</span>
        </a>
        <nav class="ml-auto hidden sm:flex gap-[26px] text-[14.5px] font-medium">
          <a href="/tutorial" class:list={["text-ink-soft hover:text-coral", activeNav === "教程" && "text-suit-red"]}>教程</a>
          <a href="/library" class:list={["text-ink-soft hover:text-coral", activeNav === "牌库" && "text-suit-red"]}>牌库</a>
          <a href="/suits" class:list={["text-ink-soft hover:text-coral", activeNav === "四花色" && "text-suit-red"]}>四花色</a>
          <a href="/combinations" class:list={["text-ink-soft hover:text-coral", activeNav === "组合浏览器" && "text-suit-red"]}>组合浏览器</a>
        </nav>
        <!-- 移动端汉堡按钮 -->
        <button
          id="navToggle"
          type="button"
          aria-label="打开导航菜单"
          aria-expanded="false"
          aria-controls="mobileNav"
          class="nav-toggle ml-auto sm:hidden inline-flex flex-col justify-center items-center gap-[5px] w-10 h-10 -mr-2 rounded-lg cursor-pointer"
        >
          <span class="bar block w-[22px] h-[2px] bg-ink rounded-full"></span>
          <span class="bar block w-[22px] h-[2px] bg-ink rounded-full"></span>
          <span class="bar block w-[22px] h-[2px] bg-ink rounded-full"></span>
        </button>
      </div>
      <!-- 移动端下拉菜单 -->
      <nav id="mobileNav" class="mobile-nav sm:hidden hidden border-t border-line bg-paper font-medium text-[15.5px]">
        <a href="/tutorial" class:list={["block px-7 py-[13px] border-b border-line text-ink-soft hover:text-coral hover:bg-paper-deep", activeNav === "教程" && "text-suit-red"]}>教程</a>
        <a href="/library" class:list={["block px-7 py-[13px] border-b border-line text-ink-soft hover:text-coral hover:bg-paper-deep", activeNav === "牌库" && "text-suit-red"]}>牌库</a>
        <a href="/suits" class:list={["block px-7 py-[13px] border-b border-line text-ink-soft hover:text-coral hover:bg-paper-deep", activeNav === "四花色" && "text-suit-red"]}>四花色</a>
        <a href="/combinations" class:list={["block px-7 py-[13px] text-ink-soft hover:text-coral hover:bg-paper-deep", activeNav === "组合浏览器" && "text-suit-red"]}>组合浏览器</a>
      </nav>
    </header>

    <slot />

    <!-- 页脚 -->
    <footer class="border-t border-line mt-[70px] font-sans text-[13px] text-ink-faint">
      <div class="max-w-[1200px] mx-auto px-7 py-[30px] flex justify-between gap-5 flex-wrap">
        <span>落差扑克牌占卜 · 一套非线性、叠加态的解牌体系</span>
        <span>
          <a href="/tutorial">教程</a> ·
          <a href="/library">牌库索引</a> ·
          <a href="/suits">四花色</a> ·
          <a href="/combinations">组合浏览器</a>
        </span>
      </div>
    </footer>
  </div>

  <script>
    // ── 移动端导航(每次换页都重新绑定,因 header 会被换掉) ──
    function initNav() {
      const navToggle = document.getElementById("navToggle");
      const mobileNav = document.getElementById("mobileNav");
      if (!navToggle || !mobileNav) return;
      const setOpen = (open: boolean) => {
        mobileNav.classList.toggle("hidden", !open);
        navToggle.setAttribute("aria-expanded", open ? "true" : "false");
        navToggle.classList.toggle("is-open", open);
      };
      navToggle.addEventListener("click", () => setOpen(mobileNav.classList.contains("hidden")));
      mobileNav.querySelectorAll("a").forEach((a) => a.addEventListener("click", () => setOpen(false)));
    }
    document.addEventListener("astro:page-load", initNav);
    document.addEventListener("keydown", (e) => {
      if (e.key !== "Escape") return;
      const mn = document.getElementById("mobileNav"), nt = document.getElementById("navToggle");
      if (mn && nt) { mn.classList.add("hidden"); nt.setAttribute("aria-expanded", "false"); nt.classList.remove("is-open"); }
    });

    // ════════ 单卡页跳转 · 卡片「移动放大、落到桌面」转场(无刷新) ════════
    const RATIO = 332.59947 / 238.11099; // 正面 svg 长宽比
    let pending: { key: string; origin: { x: number; y: number; w: number; h: number } } | null = null;
    const reduceMQ = window.matchMedia("(prefers-reduced-motion: reduce)");
    // 触摸屏(主指针 coarse、无 hover):等同「减少动态」,跳过整段飞行转场。
    // CSS 动画/过渡已由 global.css 的同条件媒体查询归零;此处管 WAAPI 飞行。
    const touchMQ = window.matchMedia("(hover: none) and (pointer: coarse)");
    const noMotion = () => reduceMQ.matches || touchMQ.matches;

    // 点击:只记下原位置与牌 key —— 导航交给 ClientRouter(它已拦截 <a>),
    // 落地动画在 astro:page-load 里依 pending 完成。捕获阶段,确保在 ClientRouter 之前记录。
    document.addEventListener("click", (e) => {
      const me = e as MouseEvent;
      if (me.button !== 0 || me.metaKey || me.ctrlKey || me.shiftKey || me.altKey) { pending = null; return; }
      const t = e.target as Element | null;
      const a = t && t.closest ? (t.closest('a[href^="/cards/"]') as HTMLAnchorElement | null) : null;
      if (!a || a.getAttribute("target") === "_blank") { pending = null; return; }
      let url: URL;
      try { url = new URL(a.href, location.href); } catch { pending = null; return; }
      if (url.origin !== location.origin || noMotion()) { pending = null; return; }

      const parts = url.pathname.split("/").filter(Boolean);
      const key = parts[parts.length - 1];
      const img = a.querySelector("img") as HTMLImageElement | null;
      let origin: { x: number; y: number; w: number; h: number };
      if (img) {
        const r = img.getBoundingClientRect();
        origin = { x: r.left, y: r.top, w: r.width, h: r.height };
      } else {
        const r = a.getBoundingClientRect();
        const w = Math.min(110, r.width || 110), h = w * RATIO;
        origin = { x: r.left + r.width / 2 - w / 2, y: r.top + r.height / 2 - h / 2, w, h };
      }
      pending = { key, origin };
    }, true);

    // 换页中:新页内容从纸色淡入(背景渐变过渡);若是飞牌进入,先藏起目标 hero 卡
    document.addEventListener("astro:after-swap", () => {
      const pw = document.querySelector(".page-wrap") as HTMLElement | null;
      if (pw) pw.classList.add("cf-pagein");
      if (!pending) return;
      const card = document.querySelector("main .card") as HTMLElement | null;
      if (card) card.style.visibility = "hidden";
    });

    // 换页完成 → 牌从原位移动放大、悬停后落到桌面;落定后卡片边饰从内向外滑出
    document.addEventListener("astro:page-load", () => {
      if (!pending) {
        // 直接进入单卡页(非飞牌):让边饰滑出一次 —— 但原地刷新(reload)时不放,避免每次刷新重播动画
        const navEntry = performance.getEntriesByType("navigation")[0] as PerformanceNavigationTiming | undefined;
        const isReload = navEntry?.type === "reload";
        const c = document.querySelector("main .card") as HTMLElement | null;
        if (c && !isReload) c.classList.add("cf-arrived");
        return;
      }
      const { key, origin } = pending;
      const card = document.querySelector("main .card") as HTMLElement | null;
      const real = document.querySelector("main .card .cardimg") as HTMLElement | null;
      const FLY = 900;
      let settling = false, done = false;
      // 牌抵达目标、开始落定时调用:露出真卡的边饰(随 .cf-arrived 由内向外展开),
      // 同时藏起真卡牌面 —— 让仍在的飞行牌盖住中心,只露出四周边饰/金框/阴影在展开。
      const startSettle = () => {
        if (settling) return; settling = true;
        if (card) { card.style.visibility = ""; card.classList.add("cf-arrived"); }
        if (real) real.style.visibility = "hidden";
      };
      // 飞行结束:撤掉飞行牌,露出真卡牌面(此刻边饰已在展开过程中)
      const land = () => {
        if (done) return; done = true;
        startSettle();
        document.getElementById("cardflip-stage")?.remove();
        if (real) real.style.visibility = "";
        pending = null;
      };
      if (!real || !card) { land(); return; }

      const rr = real.getBoundingClientRect();
      // 中心用包围盒(旋转安全);尺寸用 offsetWidth/Height —— 真卡有 -2° 旋转,
      // 包围盒会比实际宽约 5%,若用它做落定缩放,交接到真卡时会突然缩小。
      const tw = real.offsetWidth || rr.width, th = real.offsetHeight || rr.height;
      const ocx = origin.x + origin.w / 2, ocy = origin.y + origin.h / 2;
      const tcx = rr.left + rr.width / 2, tcy = rr.top + rr.height / 2;
      const dx = tcx - ocx, dy = tcy - ocy;
      const sEnd = tw / origin.w;   // 落定缩放(与真卡实际同大)
      const sOver = sEnd * 1.09;    // 悬停时略大于真卡

      // 等根过渡的快照撤掉(下一帧)再放飞,确保整段移动都看得见
      requestAnimationFrame(() => requestAnimationFrame(() => {
        const stage = document.createElement("div");
        stage.id = "cardflip-stage";
        stage.style.left = origin.x + "px";
        stage.style.top = origin.y + "px";
        stage.style.width = origin.w + "px";
        stage.style.height = origin.h + "px";
        const face = document.createElement("img");
        face.className = "cf-face";
        face.src = "/cards_svg/" + key + ".svg";
        stage.append(face);
        document.body.append(stage);

        const anim = stage.animate(
          [
            // 起:原位、原大小
            { transform: "translate(0px,0px) scale(1) rotate(0deg)",
              filter: "drop-shadow(0 8px 16px rgba(43,39,34,0.20))",
              offset: 0, easing: "cubic-bezier(0.33,0.45,0.4,1)" },
            // 移动 + 逐渐放大,到目标上方悬停(略大于真卡、投影最大)
            { transform: `translate(${dx}px,${dy}px) scale(${sOver}) rotate(-2.5deg)`,
              filter: "drop-shadow(0 46px 66px rgba(43,39,34,0.42))",
              offset: 0.72, easing: "cubic-bezier(0.45,0,0.35,1)" },
            // 落到桌面:回到真卡大小与 -2° 静止态;投影几乎收没,余下交给真卡阴影缓慢渐显
            { transform: `translate(${dx}px,${dy}px) scale(${sEnd}) rotate(-2deg)`,
              filter: "drop-shadow(0 3px 8px rgba(43,39,34,0.10))",
              offset: 1 },
          ] as Keyframe[],
          { duration: FLY, easing: "linear", fill: "forwards" }
        );
        anim.addEventListener("finish", land, { once: true });
        // 牌一抵达目标(0.72)即开始落定:边饰与下压的牌同步展开,而非落定后才展开
        window.setTimeout(startSettle, FLY * 0.72);
      }));
      window.setTimeout(land, FLY + 800); // 看门狗
    });

    // 离开页面前清掉叠加态 body class,避免残留到下一页
    document.addEventListener("astro:before-swap", () => {
      document.body.classList.remove("reverse", "shadow");
    });
  </script>

  <style>
    /* 汉堡按钮 → X 动画 */
    .nav-toggle .bar { transition: transform 0.25s ease, opacity 0.2s ease; }
    .nav-toggle.is-open .bar:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .nav-toggle.is-open .bar:nth-child(2) { opacity: 0; }
    .nav-toggle.is-open .bar:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
  </style>
</body>
</html>
