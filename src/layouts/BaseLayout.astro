---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";

interface Props {
  title: string;
  activeNav?: "教程" | "占卜守则" | "牌库" | "四花色" | "组合浏览器";
}

const { title, activeNav } = Astro.props;
---
<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} · 落差扑克牌占卜</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <!-- 客户端路由:换页不刷新,卡片转场在其生命周期里完成 -->
  <ClientRouter />
  <!-- 预加载首屏关键字重(本地子集字体,各 ~230-300KB):正文/UI 黑体 400、正文宋体 400、hero 标题宋体 900 -->
  <link rel="preload" href="/fonts/noto-sans-sc-400.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/fonts/noto-serif-sc-400.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/fonts/noto-serif-sc-900.woff2" as="font" type="font/woff2" crossorigin>
</head>
<body>
  <!-- SVG 纹理滤镜（全局共用） -->
  <svg class="rough-filter" aria-hidden="true">
    <defs>
      <filter id="rough">
        <feTurbulence type="fractalNoise" baseFrequency="0.018" numOctaves="3" seed="7" result="n" />
        <feDisplacementMap in="SourceGraphic" in2="n" scale="3.2" xChannelSelector="R" yChannelSelector="G" />
      </filter>
    </defs>
  </svg>

  <div class="page-wrap">
    <!-- 导航栏 -->
    <header class="sticky top-0 z-40 border-b border-line bg-[rgba(250,246,239,0.88)] backdrop-blur-[8px] font-sans">
      <div class="max-w-[1280px] mx-auto px-8 py-[14px] flex items-center gap-[22px]">
        <a href="/" class="flex items-center gap-[11px] font-bold tracking-[0.02em] text-ink text-base no-underline">
          <span class="font-serif text-[21px] text-suit-red leading-none tracking-[-2px]" aria-hidden="true">
            <span>♥</span><span class="text-ink">♠</span>
          </span>
          <span>落差扑克牌占卜</span>
        </a>
        <nav class="ml-auto hidden sm:flex gap-2 text-[14.5px] font-medium">
          <a href="/tutorial" class:list={["px-2.5 py-1.5 transition-colors", activeNav === "教程" ? "text-coral" : "text-ink-soft hover:text-coral"]}>教程</a>
          <a href="/divination" class:list={["px-2.5 py-1.5 transition-colors", activeNav === "占卜守则" ? "text-coral" : "text-ink-soft hover:text-coral"]}>占卜守则</a>
          <a href="/library" class:list={["px-2.5 py-1.5 transition-colors", activeNav === "牌库" ? "text-coral" : "text-ink-soft hover:text-coral"]}>牌库</a>
          <a href="/suits" class:list={["px-2.5 py-1.5 transition-colors", activeNav === "四花色" ? "text-coral" : "text-ink-soft hover:text-coral"]}>四花色</a>
          <a href="/combinations" class:list={["px-2.5 py-1.5 transition-colors", activeNav === "组合浏览器" ? "text-coral" : "text-ink-soft hover:text-coral"]}>组合浏览器</a>
        </nav>
        <!-- 移动端汉堡按钮 -->
        <button
          id="navToggle"
          type="button"
          aria-label="打开导航菜单"
          aria-expanded="false"
          aria-controls="mobileNav"
          class="nav-toggle ml-auto sm:hidden inline-flex flex-col justify-center items-center gap-[5px] w-10 h-10 -mr-2 rounded-lg cursor-pointer"
        >
          <span class="bar block w-[22px] h-[2px] bg-ink rounded-full"></span>
          <span class="bar block w-[22px] h-[2px] bg-ink rounded-full"></span>
          <span class="bar block w-[22px] h-[2px] bg-ink rounded-full"></span>
        </button>
      </div>
      <!-- 移动端下拉菜单 -->
      <nav id="mobileNav" class="mobile-nav sm:hidden hidden absolute top-full inset-x-0 z-50 border-t border-line bg-paper font-medium text-[15.5px] shadow-[0_16px_30px_-12px_rgba(43,39,34,0.45)]">
        <a href="/tutorial" class:list={["block px-7 py-[13px] border-b border-line transition-colors", activeNav === "教程" ? "text-coral" : "text-ink-soft hover:text-coral hover:bg-paper-deep"]}>教程</a>
        <a href="/divination" class:list={["block px-7 py-[13px] border-b border-line transition-colors", activeNav === "占卜守则" ? "text-coral" : "text-ink-soft hover:text-coral hover:bg-paper-deep"]}>占卜守则</a>
        <a href="/library" class:list={["block px-7 py-[13px] border-b border-line transition-colors", activeNav === "牌库" ? "text-coral" : "text-ink-soft hover:text-coral hover:bg-paper-deep"]}>牌库</a>
        <a href="/suits" class:list={["block px-7 py-[13px] border-b border-line transition-colors", activeNav === "四花色" ? "text-coral" : "text-ink-soft hover:text-coral hover:bg-paper-deep"]}>四花色</a>
        <a href="/combinations" class:list={["block px-7 py-[13px] transition-colors", activeNav === "组合浏览器" ? "text-coral" : "text-ink-soft hover:text-coral hover:bg-paper-deep"]}>组合浏览器</a>
      </nav>
    </header>

    <slot />

    <!-- 页脚 -->
    <footer class="border-t border-line mt-[70px] font-sans text-[13px] text-ink-faint">
      <div class="max-w-[1280px] mx-auto px-8 py-[30px] flex justify-between gap-5 flex-wrap">
        <span>落差扑克牌占卜 · 一套非线性、叠加态的解牌体系</span>
        <span class="flex flex-wrap gap-x-1 gap-y-1 items-center">
          <a href="/tutorial" class="inline-block py-1">教程</a> ·
          <a href="/divination" class="inline-block py-1">占卜守则</a> ·
          <a href="/library" class="inline-block py-1">牌库索引</a> ·
          <a href="/suits" class="inline-block py-1">四花色</a> ·
          <a href="/combinations" class="inline-block py-1">组合浏览器</a>
        </span>
      </div>
    </footer>
  </div>

  <script>
    // ── 移动端导航(每次换页都重新绑定,因 header 会被换掉) ──
    function initNav() {
      const navToggle = document.getElementById("navToggle");
      const mobileNav = document.getElementById("mobileNav");
      if (!navToggle || !mobileNav) return;
      const setOpen = (open: boolean) => {
        mobileNav.classList.toggle("hidden", !open);
        navToggle.setAttribute("aria-expanded", open ? "true" : "false");
        navToggle.classList.toggle("is-open", open);
      };
      navToggle.addEventListener("click", () => setOpen(mobileNav.classList.contains("hidden")));
      mobileNav.querySelectorAll("a").forEach((a) => a.addEventListener("click", () => setOpen(false)));
    }
    document.addEventListener("astro:page-load", initNav);
    // 关闭叠层菜单的公共逻辑(顶层绑定一次,避免 SPA 换页时监听泄漏)
    const closeMobileNav = () => {
      const mn = document.getElementById("mobileNav"), nt = document.getElementById("navToggle");
      if (mn && nt) { mn.classList.add("hidden"); nt.setAttribute("aria-expanded", "false"); nt.classList.remove("is-open"); }
    };
    document.addEventListener("keydown", (e) => { if (e.key === "Escape") closeMobileNav(); });
    // 点击菜单与汉堡按钮以外的区域 → 收起叠层菜单
    document.addEventListener("click", (e) => {
      const mn = document.getElementById("mobileNav"), nt = document.getElementById("navToggle");
      if (!mn || !nt || mn.classList.contains("hidden")) return;
      const t = e.target as Node;
      if (mn.contains(t) || nt.contains(t)) return;
      closeMobileNav();
    });

    // ════════ 库 → 单卡页:卡片「飞入落桌」转场(无刷新) ════════
    // 点击库卡 → 克隆真卡从库位平移放大飞到 hero 位,飞行时浮起(投影放大)+ 末了过冲胀大,
    // 抵达后缩回原位 + 投影收紧落定 → 亮出真卡。reduced-motion / 刷新 / 直接进入不触发,直接静态呈现。
    const FLY = 650, DROP = 520, OVERSHOOT = 1.06;   // 飞入 / 落下时长(ms)与悬空过冲比例
    const CARD_RATIO = 332.59947 / 238.11099;        // 正面 svg 长宽比(无图链接据此估起飞高度)
    const reduceMQ = window.matchMedia("(prefers-reduced-motion: reduce)");
    type Rect = { x: number; y: number; w: number; h: number };
    type Flight = { w: number; h: number; cx: number; cy: number; fromScale: number; dx: number; dy: number };
    let origin: Rect | null = null;                  // 本次点击的起飞矩形;null = 非飞牌进入
    let activeFlight: (() => void) | null = null;    // 当前在飞那一程的收尾函数;换页时强制收尾,杜绝上一程的定时器/动画回调误伤下一程

    const heroCard = () => document.querySelector("main .card") as HTMLElement | null;
    const clearStages = () => document.querySelectorAll("#cardflip-stage").forEach((s) => s.remove());
    // 飞行期禁 header 的 backdrop-blur:它是 Safari 合成层,飞牌越过顶部时持续重采样下方内容、推高单帧合成成本
    const headerBackdrop = (off: boolean) => {
      const h = document.querySelector("header") as HTMLElement | null;
      if (!h) return;
      h.style.backdropFilter = off ? "none" : "";
      (h.style as any).webkitBackdropFilter = off ? "none" : "";
    };
    // 飞行起点态(offset 0):平移回库位 + 缩小 + 抵消克隆自带的 -2°。
    // mountStage 的 inline 初始 transform 与 playFlight 的首关键帧共用此式,确保逐字符一致、无跳变帧。
    const liftFrom = (g: Flight) => `translate(${g.dx}px, ${g.dy}px) scale(${g.fromScale}) rotate(2deg)`;

    // 起飞矩形:库卡优先取牌面 <img>——让克隆牌面在 t=0 等于库牌面屏宽,起手牌面无放大跳变;
    // 退回带边框卡面 .lcard,再退回链接本身按 svg 比例估算。
    function readOrigin(a: HTMLAnchorElement): Rect {
      const cardBox = a.querySelector("img") || a.querySelector(".lcard");
      if (cardBox) {
        const r = cardBox.getBoundingClientRect();
        return { x: r.left, y: r.top, w: r.width, h: r.height };
      }
      const r = a.getBoundingClientRect();
      const w = Math.min(110, r.width || 110), h = w * CARD_RATIO;
      return { x: r.left + (r.width - w) / 2, y: r.top + (r.height - h) / 2, w, h };
    }

    // 落点几何:真卡外框实际尺寸(offsetWidth/Height,不含 -2° 包围盒虚胖)、中心平移量,
    // 与让克隆牌面在 t=0 等于库牌面屏宽的起飞缩放(以 hero 牌面布局宽为分母;
    // 用 offsetWidth 而非 gBCR——.card 的 -2° 旋转会让子元素包围盒虚胖)。
    function computeFlight(from: Rect, card: HTMLElement, img: HTMLElement): Flight {
      const box = card.getBoundingClientRect();
      const w = card.offsetWidth || box.width, h = card.offsetHeight || box.height;
      const cx = box.left + box.width / 2, cy = box.top + box.height / 2;
      const imgW = img.offsetWidth || w * 0.8933;
      return { w, h, cx, cy, fromScale: from.w / imgW, dx: from.x + from.w / 2 - cx, dy: from.y + from.h / 2 - cy };
    }

    // 在 hero 位挂一张克隆牌(舞台 + 克隆);克隆首帧呈 --shadow-rest,与库卡 hover 阴影一致,
    // 浮起(cf-lift)延到 playFlight 提交首帧后再加,借 .card 的 box-shadow 0.5s 过渡渐渐离桌
    function mountStage(card: HTMLElement, g: Flight): { stage: HTMLElement; fly: HTMLElement } {
      const fly = card.cloneNode(true) as HTMLElement;
      fly.style.visibility = "";
      const stage = document.createElement("div");
      stage.id = "cardflip-stage";
      stage.style.left = g.cx - g.w / 2 + "px";
      stage.style.top = g.cy - g.h / 2 + "px";
      stage.style.width = g.w + "px";
      stage.style.height = g.h + "px";
      stage.style.transform = liftFrom(g);           // append 前就摆成飞行起点,杜绝「base 态(hero 位/全尺寸/无旋)闪一帧」
      stage.append(fly);
      document.body.append(stage);
      return { stage, fly };
    }

    // 飞入(悬空,末了过冲到 OVERSHOOT)→ 落下(缩回 scale 1 + 卸浮起态,投影经 .card 0.5s 过渡收回 rest);
    // 两段都跑完调 onLand。(克隆自带 -2°,起飞 +2° 抵消,落定回 0°。)
    // 移动段缓动:先慢 → 中段加快 → 尾端减慢(easeInOutCubic),让卡片平移放大有「起步沉、途中冲、临到缓」的手感。
    function playFlight(stage: HTMLElement, fly: HTMLElement, g: Flight, onLand: () => void) {
      void stage.getBoundingClientRect();            // 提交 mountStage 的初始 transform + rest 阴影首帧,让 WAAPI 与阴影过渡都从同一起点态无缝接管(防首帧闪)
      fly.classList.add("cf-lift");                  // 起飞:box-shadow 经 .card 0.5s 过渡从 rest 渐放大到 lift = 卡片离桌浮起
      stage.animate(
        [
          { transform: liftFrom(g) },
          { transform: `translate(0, 0) scale(${OVERSHOOT}) rotate(0deg)` },
        ],
        { duration: FLY, easing: "cubic-bezier(0.65, 0, 0.35, 1)", fill: "forwards" }
      ).addEventListener("finish", () => {
        fly.classList.remove("cf-lift");
        stage.animate(
          [
            { transform: `translate(0, 0) scale(${OVERSHOOT}) rotate(0deg)` },
            { transform: "translate(0, 0) scale(1) rotate(0deg)" },
          ],
          { duration: DROP, easing: "cubic-bezier(0.2, 0.8, 0.2, 1)", fill: "forwards" }
        ).addEventListener("finish", onLand, { once: true });
      }, { once: true });
    }

    // 编排:克隆真卡从 from 飞到 card,落定后亮出真卡(首次落定生效,看门狗兜底)。
    // land 只收自己这一程(清自己的看门狗与舞台),不全局清场——避免上一程的 land 误删下一程的飞行牌。
    function flyToCard(from: Rect, card: HTMLElement | null) {
      let landed = false;
      let timer = 0;
      let stage: HTMLElement | null = null;
      const land = () => {
        if (landed) return;
        landed = true;
        if (timer) { clearTimeout(timer); timer = 0; }
        if (stage) { stage.remove(); stage = null; }
        if (card) card.style.visibility = "";
        headerBackdrop(false);
        if (activeFlight === land) activeFlight = null;
      };
      activeFlight = land;
      headerBackdrop(true);

      const img = card?.querySelector(".cardimg") as HTMLElement | null;
      if (!card || !img) { land(); return; }

      const g = computeFlight(from, card, img);
      // 下一帧(布局稳定)放飞克隆牌(root 无 view-transition 快照,见 global.css,单 rAF 即足够);看门狗已落定则不补建,避免孤儿克隆
      requestAnimationFrame(() => {
        if (landed) return;
        const mounted = mountStage(card, g);
        stage = mounted.stage;
        playFlight(mounted.stage, mounted.fly, g, land);
      });
      timer = window.setTimeout(land, FLY + DROP + 800);   // 看门狗:rAF 未触发(标签后台)也能落定
    }

    // 捕获阶段(早于 ClientRouter)记下起飞矩形;导航本身交给 ClientRouter
    document.addEventListener("click", (e) => {
      origin = null;
      const me = e as MouseEvent;
      if (me.button !== 0 || me.metaKey || me.ctrlKey || me.shiftKey || me.altKey) return;
      const a = (e.target as Element | null)?.closest?.('a[href^="/cards/"]') as HTMLAnchorElement | null;
      if (!a || a.target === "_blank" || reduceMQ.matches) return;
      let url: URL;
      try { url = new URL(a.href, location.href); } catch { return; }
      if (url.origin !== location.origin) return;
      origin = readOrigin(a);
    }, true);

    // 换页瞬间:新页从纸色淡入;飞牌进入时先藏起目标 hero 卡(由克隆代飞)
    document.addEventListener("astro:after-swap", () => {
      document.querySelector(".page-wrap")?.classList.add("cf-pagein");
      const card = heroCard();
      if (origin && card) card.style.visibility = "hidden";
    });

    // 换页完成:飞牌进入才放飞克隆牌;否则(直接进入 / 刷新)卡片与金框直接静态呈现
    document.addEventListener("astro:page-load", () => {
      if (origin) flyToCard(origin, heroCard());
      origin = null;
    });

    // 离开页面前:强制收尾在飞那一程(取消其看门狗、移除其舞台)+ 清掉叠加态 body class + 兜底清残留飞行牌
    document.addEventListener("astro:before-swap", () => {
      document.body.classList.remove("reverse", "shadow");
      if (activeFlight) activeFlight();
      clearStages();
    });
  </script>

  <style>
    /* 汉堡按钮 → X 动画 */
    .nav-toggle .bar { transition: transform 0.25s ease, opacity 0.2s ease; }
    .nav-toggle.is-open .bar:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .nav-toggle.is-open .bar:nth-child(2) { opacity: 0; }
    .nav-toggle.is-open .bar:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

    /* 叠层菜单:出现时轻微下滑淡入(浮在内容之上,不挤压页面) */
    .mobile-nav:not(.hidden) { animation: navDrop 0.22s ease both; transform-origin: top; }
    @keyframes navDrop {
      from { opacity: 0; transform: translateY(-10px); }
      to   { opacity: 1; transform: translateY(0); }
    }
  </style>
</body>
</html>
