---
/** 分隔线组件（花饰 ❦ + 波浪 SVG） */
interface Props {
  label?: string;  // 中间文字，默认 ❦
}
const { label = "❦" } = Astro.props;
---
<div class="flex items-center gap-[18px] my-[26px] text-gold max-w-[1280px] mx-auto px-8">
  <svg viewBox="0 0 400 12" preserveAspectRatio="none" class="flex-1 h-[12px] opacity-75">
    <path d="M0 7 Q 60 1 120 6 T 240 6 T 400 6" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" />
  </svg>
  <span class="text-base tracking-[0.3em]">{label}</span>
  <svg viewBox="0 0 400 12" preserveAspectRatio="none" class="flex-1 h-[12px] opacity-75">
    <path d="M0 6 Q 160 1 280 6 T 400 7" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" />
  </svg>
</div>
